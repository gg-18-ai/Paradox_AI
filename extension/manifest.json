{
  "manifest_version": 3,
  "name": "Paradox AI Side Panel",
  "version": "1.0",
  "description": "Opens Paradox AI chat inside Chrome Side Panel during browser automation.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Paradox AI Side Panel"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src http://localhost:3000 http://127.0.0.1:3000"
  }
}
